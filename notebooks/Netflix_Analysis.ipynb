# 🎬 Netflix Data Analytics Dashboard
**Author:** Neelam Choudhary  
**Tech Stack:** Python · NumPy · Pandas · Matplotlib · Power BI  

---
This notebook walks through the end-to-end analysis of Netflix content data —
from loading and cleaning the dataset all the way to building visual insights
that were later translated into an interactive Power BI dashboard.

## 1️⃣ Import Libraries
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import warnings
warnings.filterwarnings('ignore')
print('Libraries loaded successfully ✅')
## 2️⃣ Load Dataset
# If you have the real CSV, replace the line below:
# df = pd.read_csv('data/netflix_titles.csv')

# --- Sample data generation (for demo purposes) ---
np.random.seed(42)
n = 500
genres    = ['Drama','Comedy','Documentary','Action','Thriller','Romance','Sci-Fi','Horror','Animation','Crime']
countries = ['United States','India','United Kingdom','Canada','France','Japan','South Korea','Germany']
ratings   = ['TV-MA','TV-14','TV-PG','PG-13','R','G','NR']

df = pd.DataFrame({
    'show_id'      : [f's{i}' for i in range(1, n+1)],
    'type'         : np.random.choice(['Movie','TV Show'], n, p=[0.60,0.40]),
    'title'        : [f'Title_{i}' for i in range(1, n+1)],
    'country'      : np.random.choice(countries, n, p=[0.35,0.20,0.10,0.08,0.08,0.07,0.07,0.05]),
    'release_year' : np.random.randint(2010, 2024, n),
    'rating'       : np.random.choice(ratings, n, p=[0.30,0.25,0.15,0.12,0.10,0.05,0.03]),
    'genre'        : np.random.choice(genres, n),
    'duration_min' : np.random.randint(60, 180, n),
    'views_million': np.round(np.random.exponential(5, n), 2),
    'user_rating'  : np.round(np.random.uniform(2.5, 5.0, n), 1),
})

print(f'Shape: {df.shape}')
df.head()
## 3️⃣ Data Cleaning
print('Null values before cleaning:')
print(df.isnull().sum())
df.dropna(inplace=True)
print(f'\nClean dataset shape: {df.shape}')
## 4️⃣ NumPy Statistical Analysis
views = df['views_million'].values
print('--- Views (Millions) Stats ---')
print(f'Mean   : {np.mean(views):.2f}M')
print(f'Median : {np.median(views):.2f}M')
print(f'Std Dev: {np.std(views):.2f}M')
print(f'90th % : {np.percentile(views, 90):.2f}M')
corr = np.corrcoef(df['user_rating'].values, views)[0,1]
print(f'Correlation (rating vs views): {corr:.3f}')
## 5️⃣ Visualisations
RED, DARK, LIGHT, ACCENT = '#E50914', '#141414', '#f5f5f1', '#b81d24'

fig, axes = plt.subplots(2, 2, figsize=(14, 10), facecolor=DARK)
fig.suptitle('Netflix Content Analytics Dashboard', fontsize=20, color=RED, fontweight='bold')

for ax in axes.flat:
    ax.set_facecolor('#1a1a1a')
    ax.tick_params(colors=LIGHT)

# Genre views
genre_views = df.groupby('genre')['views_million'].mean().sort_values()
axes[0,0].barh(genre_views.index, genre_views.values,
               color=[RED if v==genre_views.max() else ACCENT for v in genre_views.values])
axes[0,0].set_title('Avg Views by Genre (M)', color=LIGHT)

# Type pie
tc = df['type'].value_counts()
axes[0,1].pie(tc, labels=tc.index, autopct='%1.1f%%',
              colors=[RED,'#555'], wedgeprops=dict(width=0.5),
              textprops={'color':LIGHT})
axes[0,1].set_title('Movies vs TV Shows', color=LIGHT)

# Year trend
yc = df['release_year'].value_counts().sort_index()
axes[1,0].plot(yc.index, yc.values, color=RED, lw=2, marker='o', ms=4)
axes[1,0].fill_between(yc.index, yc.values, alpha=0.2, color=RED)
axes[1,0].set_title('Titles per Year', color=LIGHT)

# Top countries
top = df['country'].value_counts().head(5)
axes[1,1].bar(top.index, top.values, color=[RED,ACCENT,'#8B0000','#666','#444'])
axes[1,1].set_title('Top 5 Countries', color=LIGHT)
axes[1,1].tick_params(axis='x', rotation=20)

plt.tight_layout()
plt.savefig('screenshots/netflix_dashboard.png', dpi=150, facecolor=DARK)
plt.show()
print('Dashboard saved!')
## 6️⃣ Key Findings
- **Drama** and **Action** genres consistently drive the highest average views
- **60%** of Netflix content is Movies; **40%** are TV Shows
- Content production peaked between **2018–2022**
- **USA and India** are the largest content-producing countries
- User rating shows a **weak positive correlation** with views — quality helps but isn't the only driver
